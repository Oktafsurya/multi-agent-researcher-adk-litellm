# ─────────────────────────────────────────────
# AWS Bedrock Credentials
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token
AWS_REGION_NAME=ap-southeast-1

# ─────────────────────────────────────────────
# LiteLLM Proxy
# ─────────────────────────────────────────────
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-local-master-key-change-me

# ─────────────────────────────────────────────
# Redis (for LiteLLM response caching)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=redis

# ─────────────────────────────────────────────
# PostgreSQL — researcher memory store
# litellm-db is mapped to host port 5433
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://litellm:litellm_secret@localhost:5433/litellm

# ─────────────────────────────────────────────
# Langfuse (observability)
# Get keys from: https://cloud.langfuse.com
# or your self-hosted instance
# ─────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
